{
    "name": "tecdiary/sma",
    "version": "3.5.5",
    "description": "Stock Manager Advance",
    "type": "project",
    "require": {
        "php": "^8.2",
        "dompdf/dompdf": "^3.0",
        "hybridauth/hybridauth": "^3.10",
        "mike42/escpos-php": "^4.0",
        "mpdf/mpdf": "^8.2",
        "phpmailer/phpmailer": "^6.9",
        "stripe/stripe-php": "^7.128",
        "tecdiary/sms": "^1.0.2",
        "league/oauth2-google": "^4.0",
        "laminas/laminas-barcode": "^2.14",
        "phpoffice/phpspreadsheet": "^2.3",
        "arutil/ar-php": "^0.1.1",
        "salla/zatca": "^3.0",
        "chillerlan/php-qrcode": "^4.4",
        "nesbot/carbon": "^2.72.6"
    },
    "license": "Commercial License",
    "authors": [
        {
            "name": "Mian Saleem",
            "email": "saleem@tecdiary.com"
        }
    ],
    "repositories": [
        {
            "type": "package",
            "package": {
                "name": "arutil/ar-php",
                "version": "0.1.1",
                "dist": {
                    "url": "https://github.com/alhoqbani/ar-php/archive/refs/heads/master.zip",
                    "type": "zip"
                },
                "require": {
                    "php": ">=7.4",
                    "nesbot/carbon": "^1.22 || ^2.0 || ^3.0"
                },
                "autoload": {
                    "psr-4": {
                        "ArUtil\\": "src/ArUtil"
                    },
                    "files": [
                        "src/bootstrap.php"
                    ]
                }
            }
        }
    ],
    "config": {
        "platform": {
            "php": "8.2"
        },
        "allow-plugins": {
            "kylekatarnls/update-helper": true
        },
        "platform-check": false
    }
}
